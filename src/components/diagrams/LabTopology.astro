---
// "Two boxes, one system" — the MS-01 + external drive cage architecture,
// drawn as zones the way the build actually layers: network, compute,
// interconnect, storage, with power as its own domain on the right.
// Strokes and fills bind to theme tokens (see ARTICLE DIAGRAMS in global.css)
// so the diagram re-themes with the palette like code blocks do.
---

<figure class="article-diagram">
  <svg viewBox="0 0 720 648" role="img" aria-label="Diagram: four stacked zones — network, compute, interconnect, storage — showing a 10-gig switch feeding a Minisforum MS-01, whose HBA runs two SAS cables to a five-bay drive cage, with a separate power domain column on the right">
    <defs>
      <marker id="lt-a" markerWidth="9" markerHeight="9" refX="6" refY="3" orient="auto">
        <path class="dg-arrow" d="M0,0 L6,3 L0,6 Z" />
      </marker>
    </defs>

    <!-- zone bands -->
    <rect class="dg-zone" x="0" y="16" width="720" height="72" />
    <rect class="dg-zone" x="0" y="100" width="528" height="232" />
    <rect class="dg-zone" x="0" y="344" width="528" height="80" />
    <rect class="dg-zone" x="0" y="436" width="528" height="196" />
    <rect class="dg-zone" x="540" y="100" width="180" height="532" />

    <text class="dg-t-zone" x="12" y="40">Network</text>
    <text class="dg-t-zone" x="12" y="124">Compute</text>
    <text class="dg-t-zone" x="12" y="368">Interconnect</text>
    <text class="dg-t-zone" x="12" y="460">Storage</text>
    <text class="dg-t-zone" x="552" y="124">Power</text>

    <!-- links, under the nodes -->
    <line class="dg-line" x1="320" y1="76" x2="320" y2="106" marker-end="url(#lt-a)" />
    <text class="dg-t-mut" x="334" y="98">10 GbE</text>

    <line class="dg-line" x1="240" y1="320" x2="240" y2="442" marker-end="url(#lt-a)" />
    <line class="dg-line" x1="280" y1="320" x2="280" y2="442" marker-end="url(#lt-a)" />
    <text class="dg-t-label" x="304" y="380">2× SFF-8644 SAS</text>
    <text class="dg-t-mut" x="304" y="398">one dedicated lane per bay</text>

    <!-- power routing: UPS feeds the host and the cage PSU; the PSU feeds the cage -->
    <line class="dg-line dg-dash" x1="552" y1="168" x2="504" y2="168" marker-end="url(#lt-a)" />
    <line class="dg-line dg-dash" x1="630" y1="196" x2="630" y2="228" marker-end="url(#lt-a)" />
    <path class="dg-line dg-dash" d="M630 300 L630 530 L504 530" marker-end="url(#lt-a)" />

    <!-- Network -->
    <g>
      <rect class="dg-node" x="180" y="28" width="280" height="48" rx="2" />
      <text class="dg-t-title" x="196" y="48">10-gig switch</text>
      <text class="dg-t-mut" x="196" y="66">SFP+ fiber · both MS-01 ports</text>
    </g>

    <!-- MS-01 -->
    <g>
      <rect class="dg-node" x="100" y="112" width="400" height="208" rx="2" />
      <text class="dg-t-title" x="116" y="138">Minisforum MS-01</text>
      <text class="dg-t-mut" x="484" y="138" text-anchor="end">$849</text>
      <text class="dg-t-mut" x="116" y="156">Proxmox VE</text>
      <line class="dg-divider" x1="116" y1="166" x2="484" y2="166" />
      <text class="dg-t-label" x="116" y="186">i5-12600H · Quick Sync transcode engine</text>
      <text class="dg-t-label" x="116" y="204">64 GB DDR5 · 2× NVMe · 2× 10 GbE SFP+</text>
      <rect class="dg-accent-soft" x="116" y="216" width="368" height="56" rx="2" />
      <text class="dg-t-label" x="130" y="236">LSI 9300-8e · flashed to IT mode</text>
      <text class="dg-t-mut" x="470" y="236" text-anchor="end">$120 used</text>
      <text class="dg-t-mut" x="130" y="254">PCIe 4.0 ×8 · raw disks + SMART, nothing else</text>
      <text class="dg-t-mut" x="116" y="300">no temp sensor · Noctua + 15-minute watchdog</text>
    </g>

    <!-- Drive cage -->
    <g>
      <rect class="dg-node" x="100" y="448" width="400" height="172" rx="2" />
      <text class="dg-t-title" x="116" y="474">SilverStone FS305</text>
      <text class="dg-t-mut" x="484" y="474" text-anchor="end">$150</text>
      <text class="dg-t-mut" x="116" y="492">passive backplane · no expander · too simple to fail</text>
      <rect class="dg-soft" x="116" y="504" width="64" height="56" rx="1" />
      <rect class="dg-soft" x="190" y="504" width="64" height="56" rx="1" />
      <rect class="dg-soft" x="264" y="504" width="64" height="56" rx="1" />
      <rect class="dg-soft" x="338" y="504" width="64" height="56" rx="1" />
      <rect class="dg-soft" x="412" y="504" width="64" height="56" rx="1" />
      <text class="dg-t-label" x="148" y="528" text-anchor="middle">Exos</text>
      <text class="dg-t-label" x="222" y="528" text-anchor="middle">Exos</text>
      <text class="dg-t-label" x="296" y="528" text-anchor="middle">Exos</text>
      <text class="dg-t-label" x="370" y="528" text-anchor="middle">Exos</text>
      <text class="dg-t-label" x="444" y="528" text-anchor="middle">Exos</text>
      <text class="dg-t-mut" x="148" y="546" text-anchor="middle">18 TB</text>
      <text class="dg-t-mut" x="222" y="546" text-anchor="middle">18 TB</text>
      <text class="dg-t-mut" x="296" y="546" text-anchor="middle">18 TB</text>
      <text class="dg-t-mut" x="370" y="546" text-anchor="middle">18 TB</text>
      <text class="dg-t-mut" x="444" y="546" text-anchor="middle">18 TB</text>
      <text class="dg-t-label" x="116" y="584">5× recertified SAS · $2,134.64 the lot</text>
      <text class="dg-t-mut" x="116" y="604">RAIDZ2 · survives any two · 81.8 T raw → ~48 T usable</text>
    </g>

    <!-- Power column -->
    <g>
      <rect class="dg-node" x="552" y="140" width="156" height="56" rx="2" />
      <text class="dg-t-label" x="566" y="162">APC 1500 UPS</text>
      <text class="dg-t-mut" x="566" y="180">everything lands here</text>
    </g>
    <g>
      <rect class="dg-node" x="552" y="228" width="156" height="72" rx="2" />
      <text class="dg-t-label" x="566" y="250">Flex ATX 300 W</text>
      <text class="dg-t-mut" x="566" y="268">own power domain</text>
      <text class="dg-t-mut" x="566" y="284">$10 jumper · headless</text>
    </g>
  </svg>
  <figcaption>Two boxes, one system. The switch feeds the MS-01, the HBA hands ZFS raw disks, the cage adds nothing but lanes — and the drive power domain is its own, with everything landing on the same UPS.</figcaption>
</figure>
