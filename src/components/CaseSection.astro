---
interface Props {
  eyebrow: string;
  title: string;
  variant?: 'default' | 'cream';
}
const { eyebrow, title, variant = 'default' } = Astro.props;
---

<section class={`case-section${variant === 'cream' ? ' case-section--cream' : ''}`}>
  <div class="case-grid">
    <div class="reveal">
      <div class="case-eyebrow">{eyebrow}</div>
      <h2 class="case-h2">{title}</h2>
    </div>
    <div class="reveal">
      <slot />
    </div>
  </div>
</section>
