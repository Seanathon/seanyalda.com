---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import WorkCard from '../../components/WorkCard.astro';
import PhotoStrip from '../../components/PhotoStrip.astro';

const caseStudies = (await getCollection('caseStudies'))
  .filter(cs => !cs.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Shipped, self-initiated products. Entries graduate to full case studies
// (and out of this list) once their write-ups are published.
const products = [
  {
    name: 'Breaking Changes',
    status: 'Live · Open source',
    description:
      'Plan major-version upgrades in minutes: aggregated breaking changes for any GitHub dependency, analyzed by your own LLM. Web app, zero-dependency CLI, and a Claude Code skill.',
    links: [
      { href: 'https://breakingchanges.ai', label: 'breakingchanges.ai' },
      { href: 'https://github.com/Seanathon/breakingchanges', label: 'GitHub' },
    ],
  },
  {
    name: 'Board',
    status: 'v0.2 alpha · Open source',
    description:
      'Self-hosted curation where AI composes opinionated boards for whatever you collect. Single-node, SQLite-portable, and built to stay beautiful with AI turned off.',
    links: [{ href: 'https://github.com/Seanathon/board', label: 'GitHub' }],
  },
  {
    name: 'The Cube',
    status: 'Live · HYWN',
    description:
      'A 4,000-year-old imagining ritual as an async web experience — play it, and receive an oil painting of what you pictured alongside a personal interpretation.',
    links: [{ href: 'https://cube.hywn.com', label: 'cube.hywn.com' }],
  },
];
---

<BaseLayout
  title="Work — Sean Yalda"
  description="Selected work by Sean Yalda — client case studies plus shipped products: Breaking Changes, Board, and The Cube."
  active="work"
  footerDisplay="Building at the<br>intersection of<br>product, design<br>&amp; code."
>
  <Hero
    headline="Selected"
    headlineEm="case studies."
    tag="Work · 2014 – Present"
    bgImage="/assets/img/bryson-canyon.webp"
    bgCredit="Photography — <em>Sean Yalda</em> · Bryce Canyon, Utah"
    contact={[
      { href: 'mailto:seanyalda@pm.me', label: 'seanyalda@pm.me' },
      { href: 'https://linkedin.com/in/sean-yalda', label: 'LinkedIn', external: true },
      { href: 'https://github.com/Seanathon', label: 'GitHub', external: true },
    ]}
    short
  />

  <Section label="Recent work" display="Projects.">
    <div class="work-grid">
      {caseStudies.map((cs, i) => (
        <WorkCard
          num={String(i + 1).padStart(2, '0')}
          company={cs.data.company ?? cs.data.title}
          title={`${cs.data.role.replace(/\.$/, '')} · ${cs.data.period}`}
          description={cs.data.summary}
          href={`/work/${cs.id}`}
          slug={cs.id}
        />
      ))}
      <WorkCard
        num="+"
        company="More on the way"
        title="Sayari · Sun Communities · City of Detroit"
        description='Case studies for current and earlier client work are in the queue. In the meantime, see the <a href="/about" style="color: var(--accent);">about page</a> for the full client list.'
        placeholder
      />
    </div>
  </Section>

  <Section label="Shipped & self-initiated" display="Products.">
    <ul class="product-list">
      {products.map(p => (
        <li class="product-item reveal">
          <div class="product-head">
            <span class="product-name">{p.name}</span>
            <span class="product-status">{p.status}</span>
          </div>
          <p class="product-desc">{p.description}</p>
          <div class="product-links">
            {p.links.map(l => (
              <a href={l.href} target="_blank" rel="noopener">
                {l.label}
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                  <path d="M2 8L8 2M8 2H3M8 2v5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                </svg>
              </a>
            ))}
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <PhotoStrip
    src="/assets/img/grand-teton.webp"
    alt="Grand Teton range"
    location="Grand Teton · Wyoming"
  />
</BaseLayout>
