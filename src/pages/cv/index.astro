    highlights: ['Mixpanel'],
    items: ['Open Telemetry', 'Langfuse', 'HubSpot, Salesforce integrations', 'Express, Fastify API', 'SQL schema design', 'DeepEval'],
  },
  {
    label: 'Methods & Tools',
    highlights: [],
    items: ['Agile/Scrum, Jira', 'TDD (Jest, Enzyme)', 'Information Architecture', 'Headless CMS (Prismic)', 'UX/UI Design', 'OOP & Functional Programming', 'Technical Product Management'],
  },
];

const recognition = [
  { type: 'Patent', title: 'System and Method for Delivering Augmented Reality to Printed Books', meta: 'USPTO · Jul 2016' },
  { type: 'Award', title: '1st Place, Sayari AI Hackathon', meta: 'Sayari · 2026' },
  { type: 'Award', title: '1st Place & Community Choice, 6th Annual Detroit Startup Weekend', meta: 'Nov 2014' },
  { type: 'Talk', title: 'Fundamentals of Data Modelling: Why it Matters and How to Get Started', meta: 'SingleSprout Speaker Series' },
