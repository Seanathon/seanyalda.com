---

<BaseLayout
  title="Curriculum Vitae — Sean Yalda"
  description="Sean Yalda — Senior full-stack engineer. Twelve years across AI orchestration, platform infrastructure, and human learning. Selected experience, capabilities, recognition, and education."
  ogImage="/assets/img/bryson-canyon.webp"
  footerDisplay="Building at the<br>intersection of<br>product, design<br>&amp; code."
  footerCopy="Sean Yalda · Curriculum Vitae<br>Los Angeles · 2026"
>
  <Hero
    headline="Twelve years across<br>AI, platform, and"
    headlineEm="human learning."
    tag="Curriculum Vitae · Sean Yalda · Senior Full Stack Engineer · 2026"
    bgImage="/assets/img/bryson-canyon.webp"
    bgCredit="Photography — <em>Sean Yalda</em> · Bryce Canyon, Utah"
    contact={[
      { href: 'mailto:seanyalda@pm.me', label: 'seanyalda@pm.me' },
      { href: 'tel:+15862954265', label: '(586) 295-4265' },
      { href: 'https://linkedin.com/in/sean-yalda', label: 'LinkedIn', external: true },
      { href: 'https://github.com/Seanathon', label: 'GitHub', external: true },
      { href: '/assets/files/Sean_Yalda_Resume_ATS-2026.pdf', label: 'Download PDF', external: true },
    ]}
    cta={{ href: '#experience', label: 'View Experience' }}
  />

  <Statement headline="Engineering, design,<br>and pedagogy as<br>one practice.">
    <p>
      Senior full-stack engineer with 12+ years architecting enterprise platform infrastructure, AI-augmented pipelines, and education-sector applications. Deep across the backend: authentication, learner data models, content delivery, platform abstractions. Most major products extend to full ownership, with UX design and frontend implementation delivered alongside the architecture as a single unit.
    </p>
    <p>
      Building and shipping production AI orchestration with LangGraph.js, Vertex AI, and the Anthropic API. LLM integration and agentic tooling are central to daily engineering, not peripheral.
    </p>
    <p>
      Founding engineer at PlayVS, scaled from MVP through a $50M Series C across 30+ NFHS-sanctioned states. U.S. patent in augmented reality for printed books. Adjunct lecturer at Oakland University, 160+ hours of curriculum translating pedagogical intent into structured learning architecture.
    </p>
  </Statement>

  <Section id="experience" label="Work History" display="Experience.">
    {roles.map(r => (
      <div class="role-item reveal">
        <span class="role-num">{r.num}</span>
        <div>
          <div class="role-company">{r.company}</div>
          <div class="role-title">{r.title}</div>
          <div class="role-context">{r.context}</div>
          <ul class="role-bullets">
            {r.bullets.map(b => <li set:html={b}></li>)}
          </ul>
        </div>
        <div class="role-dates">
          <Fragment set:html={r.dates} />
          {r.badge && <><br /><div class="badge">{r.badge}</div></>}
        </div>
      </div>
    ))}
  </Section>

  <Section id="skills" variant="surface" label="Technical Capabilities" display="Skills.">
    <div class="skills-grid">
      {skills.map(s => (
        <div class="skill-cat reveal">
          <div class="skill-cat-label">{s.label}</div>
          <ul class="skill-list">
            {s.highlights.map(h => <li class="highlight">{h}</li>)}
            {s.items.map(i => <li>{i}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </Section>

  <PhotoStrip
    src="/assets/img/iceland-farms.webp"
    alt="Icelandic valley farms at golden hour"
    location="Suðurland · Iceland"
  />

  <Section id="recognition" label="Awards, Patents, Talks" display="Recognition.">
    <div class="rec-grid">
      {recognition.map(r => (
        <div class="rec-item reveal">
          <div class="rec-type">{r.type}</div>
          <div class="rec-title">{r.title}</div>
          <div class="rec-meta">{r.meta}</div>
        </div>
      ))}
    </div>
  </Section>

  <PhotoStrip
    src="/assets/img/grand-teton.webp"
    alt="Grand Teton range in autumn"
    location="Grand Teton · Wyoming"
    tall
  />

  <Section variant="cream" label="Education" display="Education.">
    <ul class="edu-list">
      {education.map(([school, program]) => (
        <li class="edu-item reveal">
          <span class="edu-school">{school}</span>
          <span class="edu-program">{program}</span>
        </li>
      ))}
    </ul>
  </Section>
</BaseLayout>
