---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Statement from '../components/Statement.astro';
import Section from '../components/Section.astro';
import PhotoStrip from '../components/PhotoStrip.astro';

const clients = [
  ['Sayari', 'Enterprise risk intelligence'],
  ['PlayVS', 'Student esports platform'],
  ['Alumni Association of the University of Michigan', 'Member platform · with Pitch Black Media'],
  ['Pitch Black Media', 'Digital agency'],
  ['Michigan Science Center', 'Web & brand'],
  ['City of Detroit', 'Home auction platform'],
  ['Sun Communities', 'Web & content'],
  ['FACINGS', 'Brand & web'],
  ['Oakland University', 'Advanced Web Design lecturer'],
  ['Open Source Labs', 'GraphQL Blueprint'],
  ['Prettybird Productions', 'Creative direction'],
  ['8° Plato', 'Brand & web'],
];

const services = [
  { label: 'Engineering', highlights: ['Full Stack Development', 'AI Agent Orchestration'], items: ['System Design', 'Information Architecture', 'Data & Content Modeling'] },
  { label: 'Design', highlights: ['UX / UI Design', 'Prototype Design'], items: ['Creative Direction', 'Pitch Deck Design', 'Photography'] },
  { label: 'Strategy', highlights: ['Product Management', 'Technical Consulting'], items: ['Process & Documentation', 'Cost/Value Analysis', 'Roadmap & Discovery'] },
];

const strengths = [
  { label: 'Building from zero', highlights: ['Founding engineer experience', 'MVP design & delivery'], items: ['Strategic vision', 'Scaling small teams'] },
  { label: 'Understanding users', highlights: ['User research', 'Usability testing'], items: ['Information architecture', 'Empathy-driven decision making'] },
  { label: 'Telling the story', highlights: ['Presentations & pitch design', 'Technical writing'], items: ['Editorial product thinking', 'Cross-functional translation'] },
  { label: 'Going deep', highlights: ['Data structures & algorithms', 'Production AI orchestration'], items: ['Schema & data modeling', 'Cost/value analysis'] },
];

const background = [
  { type: 'Heritage', title: 'First-generation Assyrian/Chaldean-American', meta: 'Originally from Detroit, now based in Los Angeles' },
  { type: 'Training', title: 'Majored in Graphic Design & Illustration', meta: 'Self-taught engineer and startup founder' },
  { type: 'Reach', title: 'Built products used by hundreds of thousands', meta: 'Including tools like <a href="https://cube.hywn.com" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">The Cube</a> &amp; <a href="https://breakingchanges.ai" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">BreakingChanges.ai</a>' },
  { type: 'Practice', title: 'Early adopter of AI for creative and technical workflows', meta: 'LLMs are in the daily toolchain, not the pitch deck' },
  { type: 'Travel', title: '47 U.S. states, 3 continents (so far)', meta: 'Photographs the trips' },
  { type: 'Life', title: 'Fatherhood reshaped the creative perspective', meta: 'The long game got personal' },
  { type: 'Music', title: 'Former touring musician and busker', meta: 'Still jams when the chance comes around' },
  { type: 'Craft', title: 'Hands-on with both code and carpentry', meta: 'Builds things that last' },
  { type: 'Patent', title: 'U.S. Patent holder & classified inventor', meta: 'Augmented reality for printed books · USPTO · 2016' },
  { type: 'Community', title: 'Active contributor to open source', meta: 'GraphQL Blueprint, Harness Engineering, and more' },
  { type: 'Fundraising', title: 'Helped raise over $100M through pitch design', meta: 'PlayVS Series A, B, C — and several others' },
  { type: 'Range', title: 'Solo projects and embedded teams — both work', meta: 'Reads people, fixes things, spots patterns' },
];
---

<BaseLayout
  title="About — Sean Yalda"
  description="About Sean Yalda — software engineer, designer, and former touring musician based in Los Angeles."
  active="about"
  footerDisplay="Let’s build<br>something<br><em>worth keeping.</em>"
  ogImage="/assets/img/grand-teton.webp"
>
  <Hero
    headline="About"
    headlineEm="Sean Yalda."
    tag="Designer · Engineer · Photographer · First-Gen Assyrian/Chaldean-American"
    bgImage="/assets/img/grand-teton.webp"
    bgCredit="Photography — <em>Sean Yalda</em> · Grand Teton, Wyoming"
    contact={[
      { href: 'mailto:seanyalda@pm.me', label: 'seanyalda@pm.me' },
      { href: 'https://linkedin.com/in/sean-yalda', label: 'LinkedIn', external: true },
      { href: 'https://github.com/Seanathon', label: 'GitHub', external: true },
      { href: 'https://www.instagram.com/sleepysensei/', label: 'Instagram', external: true },
    ]}
    short
  />

  <Statement headline="Making things<br>for the web<br><em>since 2002.</em>">
    <p>I started building websites in 2002 and went professional in 2011. Since then: startups, agencies, a science museum, a city government’s home-auction platform, an esports league through its Series A, B, and C. Hired as an engineer, usually doing the design too.</p>
    <p>The work has touched education, sports, music, science, real estate, art, and retail. The constant is hybrid range — information architecture, interface design, front-end, back-end, data modeling — whichever the project actually needs.</p>
    <p>Lately the center of gravity is agent systems: production AI orchestration at Sayari, self-hosted multi-agent infrastructure at home, and shipped tools like Breaking Changes and Board.</p>
  </Statement>

  <Section label="Selected Clients" display="Clients.">
    <ul class="edu-list">
      {clients.map(([name, desc]) => (
        <li class="edu-item reveal">
          <span class="edu-school">{name}</span>
          <span class="edu-program">{desc}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section variant="cream" label="What I do" display="Services.">
    <div class="skills-grid" style="border-top-color: rgba(0,0,0,0.12); border-left-color: rgba(0,0,0,0.12);">
      {services.map(s => (
        <div class="skill-cat reveal" style="background: transparent; border-bottom-color: rgba(0,0,0,0.12); border-right-color: rgba(0,0,0,0.12);">
          <div class="skill-cat-label" style="color: var(--hero-txt);">{s.label}</div>
          <ul class="skill-list">
            {s.highlights.map(h => <li class="highlight" style="color: var(--bg);">{h}</li>)}
            {s.items.map(i => <li style="color: rgba(0,0,0,0.65);">{i}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </Section>

  <Section variant="surface" label="Where I'm strongest" display="Strengths.">
    <div class="skills-grid">
      {strengths.map(s => (
        <div class="skill-cat reveal">
          <div class="skill-cat-label">{s.label}</div>
          <ul class="skill-list">
            {s.highlights.map(h => <li class="highlight">{h}</li>)}
            {s.items.map(i => <li>{i}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </Section>

  <PhotoStrip
    src="/assets/img/iceland-farms.webp"
    alt="Icelandic farms"
    location="Suðurland · Iceland"
  />

  <Section variant="cream" label="Approach" display="Narrative.">
    <div class="statement-body reveal" style="max-width: 720px; color: var(--bg); font-size: var(--fs-md);">
      <p>I work best where the lines blur — design reviews where I can read the code, architecture meetings where I can sketch. I can run the KPI conversation when it’s needed. But the products I’m proudest of came from watching one real person struggle with one real screen, and fixing that.</p>
      <p>Most mornings start by resetting the workspace: clear the bench, then build. That’s a carpentry habit as much as an engineering one. I do both, and they teach each other.</p>
      <p>The rest is photography on the road, music when the chance comes around, and a standing suspicion that the useful insight is sitting just outside the frame. Listen first. Then build.</p>
    </div>
  </Section>

  <Section label="Background" display="Notes.">
    <div class="rec-grid">
      {background.map(b => (
        <div class="rec-item reveal">
          <div class="rec-type">{b.type}</div>
          <div class="rec-title">{b.title}</div>
          <div class="rec-meta" set:html={b.meta}></div>
        </div>
      ))}
    </div>
  </Section>
</BaseLayout>
