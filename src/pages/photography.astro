---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

const photos = await getCollection('photos');

// Serialize photos into a compact JSON payload for the lightbox script.
const photoData = photos.map(p => ({
  id: p.data.id,
  src: p.data.src,
  alt: p.data.alt,
  width: p.data.width,
  height: p.data.height,
  date: p.data.date,
  year: p.data.year,
  camera: p.data.camera,
  lens: p.data.lens,
  focal: p.data.focal,
  aperture: p.data.aperture,
  shutter: p.data.shutter,
  iso: p.data.iso,
  color: p.data.color,
  bucket: p.data.bucket,
  hue: p.data.hue,
}));

// Compute bucket counts for the filter UI
const buckets = [
  { key: 'all',     label: 'All',     swatch: null },
  { key: 'neutral', label: 'Neutral', swatch: '#6b6b6b' },
  { key: 'red',     label: 'Red',     swatch: '#c43d2e' },
  { key: 'orange',  label: 'Orange',  swatch: '#e08434' },
  { key: 'yellow',  label: 'Yellow',  swatch: '#d4b53e' },
  { key: 'green',   label: 'Green',   swatch: '#5a8a4e' },
  { key: 'teal',    label: 'Teal',    swatch: '#3a8a8a' },
  { key: 'blue',    label: 'Blue',    swatch: '#3a5f9e' },
  { key: 'purple',  label: 'Purple',  swatch: '#7a4a9e' },
  { key: 'pink',    label: 'Pink',    swatch: '#c45a8a' },
];
const bucketCounts: Record<string, number> = { all: photos.length };
for (const p of photos) {
  const b = p.data.bucket ?? 'neutral';
  bucketCounts[b] = (bucketCounts[b] ?? 0) + 1;
}

// Render order: by color (hue ascending). Keep the original date-sorted index on each
// figure so the "Recent" toggle can restore it client-side without a re-fetch.
const renderOrder = photos
  .map((p, i) => ({ p, dateIndex: i }))
  .sort((a, b) => (a.p.data.hue ?? 0) - (b.p.data.hue ?? 0));
---

<BaseLayout
  title="Photography — Sean Yalda"
  description="Photography by Sean Yalda — landscape, travel, portrait. 47 U.S. states, 3 continents."
  active="photography"
  footerDisplay="Prints,<br>commissions,<br><em>collaborations.</em>"
  ogImage="/assets/img/iceland-farms.webp"
>
  <Hero
    headline="Photography."
    headlineEm="47 states. 3 continents."
    tag="Landscape · Travel · Portrait · Street"
    bgImage="/assets/img/iceland-farms.webp"
    bgCredit="All photography — <em>Sean Yalda</em>"
    contact={[
      { href: 'https://www.instagram.com/sleepysensei/', label: '@sleepysensei on Instagram', external: true },
      { href: 'mailto:seanyalda@pm.me', label: 'Print enquiries' },
    ]}
    short
  />

  <Section label="Selected work — landscape, travel, street" display="Frames." class="photo-intro" />

  <div class="photo-controls" role="toolbar" aria-label="Filter and sort photos">
    <div class="photo-filters" role="radiogroup" aria-label="Filter by dominant color">
      {buckets.filter(b => (bucketCounts[b.key] ?? 0) > 0).map(b => (
        <button
          type="button"
          class={`pill${b.key === 'all' ? ' is-active' : ''}`}
          role="radio"
          aria-checked={b.key === 'all' ? 'true' : 'false'}
          data-filter={b.key}
        >
          {b.swatch && <span class="pill-swatch" style={`background:${b.swatch}`} aria-hidden="true"></span>}
          <span class="pill-label">{b.label}</span>
          <span class="pill-count">{bucketCounts[b.key]}</span>
        </button>
      ))}
    </div>
    <div class="photo-sort" role="radiogroup" aria-label="Sort order">
      <button type="button" class="pill is-active" role="radio" aria-checked="true" data-sort="color">By color</button>
      <button type="button" class="pill" role="radio" aria-checked="false" data-sort="recent">Recent</button>
    </div>
  </div>

  <div class="photo-grid" id="photo-grid">
    {renderOrder.map(({ p, dateIndex }) => {
      const w = p.data.width ?? 1, h = p.data.height ?? 1;
      const figStyle = p.data.color ? `background-color: ${p.data.color}` : undefined;
      return (
        <figure
          data-bucket={p.data.bucket ?? 'neutral'}
          data-hue={p.data.hue ?? 0}
          data-original-index={dateIndex}
          data-aspect-w={w}
          data-aspect-h={h}
          style={figStyle}
        >
          <button
            type="button"
            class="photo-trigger"
            data-photo-index={dateIndex}
            aria-label={`Open photo ${dateIndex + 1} of ${photos.length}`}
          >
            <img src={p.data.src} alt={p.data.alt} loading="lazy" decoding="async" class="photo-img" />
          </button>
        </figure>
      );
    })}
  </div>
  <div class="photo-empty" id="photo-empty" hidden>
    <p>No photos in this color bucket.</p>
  </div>

  <!-- LIGHTBOX -->
  <div
    class="lightbox"
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Photo viewer"
    aria-hidden="true"
    hidden
  >
    <button type="button" class="lb-close" id="lb-close" aria-label="Close (Esc)">
      <svg viewBox="0 0 18 18" width="18" height="18" aria-hidden="true"><path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
    </button>
    <button type="button" class="lb-nav lb-prev" id="lb-prev" aria-label="Previous photo (Left arrow)">
      <svg viewBox="0 0 14 22" width="14" height="22" aria-hidden="true"><path d="M12 1L2 11l10 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
    </button>
    <button type="button" class="lb-nav lb-next" id="lb-next" aria-label="Next photo (Right arrow)">
      <svg viewBox="0 0 14 22" width="14" height="22" aria-hidden="true"><path d="M2 1l10 10L2 21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
    </button>
    <figure class="lb-figure">
      <img class="lb-img" id="lb-img" alt="" />
    </figure>
    <div class="lb-meta" id="lb-meta">
      <div class="lb-meta-row lb-meta-primary">
        <span class="lb-meta-counter" id="lb-counter"></span>
        <span class="lb-meta-date" id="lb-date"></span>
      </div>
      <div class="lb-meta-row lb-meta-secondary">
        <span class="lb-meta-camera" id="lb-camera"></span>
        <span class="lb-meta-lens" id="lb-lens"></span>
      </div>
      <div class="lb-meta-row lb-meta-tertiary">
        <span class="lb-meta-exposure" id="lb-exposure"></span>
      </div>
    </div>
  </div>

  <script is:inline data-astro-rerun define:vars={{ photoData }}>
    // data-astro-rerun makes Astro re-execute this script on every client-side
    // navigation (so it runs when you arrive via the SPA router, not just on
    // hard-load). AbortController scopes window/document listeners to the
    // current page so they get cleaned up before the next page rebinds.
    (function () {
      if (window.__photoPageAbort) window.__photoPageAbort.abort();
      window.__photoPageAbort = new AbortController();
      const __sig = window.__photoPageAbort.signal;

      const lb = document.getElementById('lightbox');
      if (!lb) return;
      const img = document.getElementById('lb-img');
      const counter = document.getElementById('lb-counter');
      const dateEl = document.getElementById('lb-date');
      const cameraEl = document.getElementById('lb-camera');
      const lensEl = document.getElementById('lb-lens');
      const exposureEl = document.getElementById('lb-exposure');
      const closeBtn = document.getElementById('lb-close');
      const prevBtn = document.getElementById('lb-prev');
      const nextBtn = document.getElementById('lb-next');
      const photos = photoData;
      let index = -1;
      let lastFocus = null;

      function fmtDate(iso) {
        if (!iso) return '';
        try {
          const d = new Date(iso + 'T00:00:00');
          return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        } catch (e) { return iso; }
      }

      function preload(i) {
        if (i < 0 || i >= photos.length) return;
        const im = new Image();
        im.src = photos[i].src;
      }

      function show(i) {
        if (i < 0 || i >= photos.length) return;
        index = i;
        const p = photos[i];
        img.src = p.src;
        img.alt = p.alt || `Photograph ${i + 1} of ${photos.length}`;
        counter.textContent = `${String(i + 1).padStart(3, '0')} / ${String(photos.length).padStart(3, '0')}`;
        dateEl.textContent = fmtDate(p.date);
        cameraEl.textContent = p.camera || '';
        lensEl.textContent = p.lens || '';
        const exp = [];
        if (p.focal) exp.push(p.focal);
        if (p.aperture) exp.push(p.aperture);
        if (p.shutter) exp.push(p.shutter + 's');
        if (p.iso) exp.push('ISO ' + p.iso);
        exposureEl.textContent = exp.join(' · ');
        prevBtn.disabled = i === 0;
        nextBtn.disabled = i === photos.length - 1;
        // Update URL hash for deep-linking (no scroll jump)
        history.replaceState(null, '', '#' + p.id);
        // Warm neighbours
        preload(i - 1); preload(i + 1);
      }

      function open(i) {
        lastFocus = document.activeElement;
        lb.hidden = false;
        lb.setAttribute('aria-hidden', 'false');
        document.body.classList.add('lb-open');
        requestAnimationFrame(() => lb.classList.add('lb-visible'));
        show(i);
        closeBtn.focus();
      }

      function close() {
        lb.classList.remove('lb-visible');
        lb.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('lb-open');
        history.replaceState(null, '', location.pathname + location.search);
        // Defer hidden until transition ends
        setTimeout(() => { lb.hidden = true; img.src = ''; }, 220);
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }

      function next() { if (index < photos.length - 1) show(index + 1); }
      function prev() { if (index > 0) show(index - 1); }

      // Triggers
      document.querySelectorAll('.photo-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          const i = Number(btn.dataset.photoIndex);
          if (!Number.isNaN(i)) open(i);
        });
      });

      // Controls
      closeBtn.addEventListener('click', close);
      prevBtn.addEventListener('click', prev);
      nextBtn.addEventListener('click', next);

      // Backdrop click (not inside figure/meta)
      lb.addEventListener('click', (e) => {
        if (e.target === lb || e.target.classList.contains('lb-figure')) close();
      });

      // Keyboard (scoped to this page lifetime via AbortController)
      document.addEventListener('keydown', (e) => {
        if (lb.hidden) return;
        if (e.key === 'Escape') { e.preventDefault(); close(); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); next(); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
      }, { signal: __sig });

      // Touch swipe — the gesture locks to an axis after a small slop:
      // horizontal navigates prev/next, downward dismisses. Listeners stay
      // passive (no preventDefault) so the browser's tap-click suppression
      // keeps working; sub-slop taps still fall through to the
      // backdrop-click close above.
      const figureEl = lb.querySelector('.lb-figure');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let swipe = null;
      function resetFigure(animate) {
        figureEl.style.transition = animate && !reduceMotion.matches ? 'transform 0.22s ease-out' : 'none';
        figureEl.style.transform = '';
      }
      lb.addEventListener('touchstart', (e) => {
        swipe = e.touches.length === 1
          ? { x: e.touches[0].clientX, y: e.touches[0].clientY, dx: 0, dy: 0, axis: null }
          : null;
        if (swipe) figureEl.style.transition = 'none';
      }, { passive: true });
      lb.addEventListener('touchmove', (e) => {
        if (!swipe) return;
        swipe.dx = e.touches[0].clientX - swipe.x;
        swipe.dy = e.touches[0].clientY - swipe.y;
        if (!swipe.axis && Math.hypot(swipe.dx, swipe.dy) > 12) {
          swipe.axis = Math.abs(swipe.dx) > Math.abs(swipe.dy) ? 'x' : 'y';
        }
        if (swipe.axis === 'x') {
          // Damped follow; extra resistance at the ends signals the edge.
          const atEdge = (swipe.dx > 0 && index === 0) || (swipe.dx < 0 && index === photos.length - 1);
          figureEl.style.transform = `translateX(${swipe.dx * (atEdge ? 0.12 : 0.35)}px)`;
        } else if (swipe.axis === 'y') {
          // Downward follows the finger toward dismissal; upward resists.
          figureEl.style.transform = `translateY(${swipe.dy > 0 ? swipe.dy : swipe.dy * 0.12}px)`;
        }
      }, { passive: true });
      lb.addEventListener('touchend', () => {
        if (!swipe) return;
        const { dx, dy, axis } = swipe;
        swipe = null;
        if (axis === 'y' && dy > 96) {
          // Figure keeps its offset while the lightbox fades; reset once hidden.
          close();
          setTimeout(() => resetFigure(false), 240);
          return;
        }
        resetFigure(true);
        if (axis === 'x' && Math.abs(dx) > 48) {
          if (dx < 0) next(); else prev();
        }
      });
      lb.addEventListener('touchcancel', () => {
        if (!swipe) return;
        swipe = null;
        resetFigure(false);
      });

      // Deep-link on load
      const hash = location.hash.slice(1);
      if (hash) {
        const i = photos.findIndex(p => p.id === hash);
        if (i >= 0) open(i);
      }

      // ─── JUSTIFIED ROWS LAYOUT ────────────────────────
      // Pack visible figures into rows at a target height, then scale each row
      // uniformly so it fills the container width edge-to-edge. Zero gaps; true
      // aspect preservation. Wide photos take more horizontal space within a row;
      // tall photos make their row taller.
      const grid = document.getElementById('photo-grid');
      const GAP = 12;
      function targetRowH() {
        // Responsive target row height — taller on wide screens, shorter on mobile
        const W = grid.clientWidth;
        if (W < 540) return 180;
        if (W < 900) return 220;
        if (W < 1400) return 260;
        return 300;
      }

      function layoutRows() {
        const W = grid.clientWidth;
        if (W < 1) return;
        const targetH = targetRowH();
        const figs = Array.from(grid.querySelectorAll('figure'))
          .filter(f => f.style.display !== 'none');
        let y = 0;
        let row = [];
        let rowNaturalW = 0;
        function place(scaleToFit) {
          if (!row.length) return;
          const gapsW = (row.length - 1) * GAP;
          const targetW = W - gapsW;
          // Scale: when forced (row is "full"), stretch to fit. For the trailing
          // row, never enlarge past natural (clamp scale to 1) so the last row
          // doesn't get awkwardly large if it's short.
          let scale = targetW / rowNaturalW;
          if (!scaleToFit) scale = Math.min(scale, 1);
          const h = targetH * scale;
          let x = 0;
          for (const it of row) {
            const w = it.aspect * h;
            it.f.style.left = x + 'px';
            it.f.style.top = y + 'px';
            it.f.style.width = w + 'px';
            it.f.style.height = h + 'px';
            x += w + GAP;
          }
          y += h + GAP;
          row = []; rowNaturalW = 0;
        }
        for (const f of figs) {
          const aw = Number(f.dataset.aspectW) || 1;
          const ah = Number(f.dataset.aspectH) || 1;
          const aspect = aw / ah;
          const naturalW = aspect * targetH;
          row.push({ f, aspect });
          rowNaturalW += naturalW;
          const gapsW = (row.length - 1) * GAP;
          if (rowNaturalW + gapsW >= W) place(true);
        }
        place(false);
        grid.style.height = (y > 0 ? y - GAP : 0) + 'px';
      }

      let resizeT = null;
      addEventListener('resize', () => {
        clearTimeout(resizeT);
        resizeT = setTimeout(layoutRows, 100);
      }, { signal: __sig });
      requestAnimationFrame(layoutRows);

      // ─── SKELETON FADE-IN ──────────────────────────────
      // Each .photo-img fades in once decoded; cached images flip immediately.
      document.querySelectorAll('.photo-img').forEach(img => {
        const reveal = () => img.classList.add('is-loaded');
        if (img.complete && img.naturalWidth > 0) {
          reveal();
        } else {
          img.addEventListener('load', reveal, { once: true });
          img.addEventListener('error', reveal, { once: true }); // hide skeleton on error too
        }
      });

      // ─── FILTER + SORT ─────────────────────────────────
      const empty = document.getElementById('photo-empty');
      const figures = Array.from(grid.querySelectorAll('figure'));
      const filterBtns = document.querySelectorAll('[data-filter]');
      const sortBtns = document.querySelectorAll('[data-sort]');
      let activeFilter = 'all';
      let activeSort = 'color'; // initial DOM is rendered in color order server-side

      function apply() {
        // Sort: derived from data-* attrs, no original-order array needed
        const ordered = figures.slice().sort((a, b) => {
          if (activeSort === 'color') {
            return (Number(a.dataset.hue) || 0) - (Number(b.dataset.hue) || 0);
          }
          // recent = original date-sorted index
          return (Number(a.dataset.originalIndex) || 0) - (Number(b.dataset.originalIndex) || 0);
        });
        const frag = document.createDocumentFragment();
        ordered.forEach(f => frag.appendChild(f));
        grid.appendChild(frag);
        // Filter
        let visible = 0;
        figures.forEach(f => {
          const match = activeFilter === 'all' || f.dataset.bucket === activeFilter;
          f.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        empty.hidden = visible > 0;
        layoutRows();
      }

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          activeFilter = btn.dataset.filter;
          filterBtns.forEach(b => {
            const isActive = b === btn;
            b.classList.toggle('is-active', isActive);
            b.setAttribute('aria-checked', isActive ? 'true' : 'false');
          });
          apply();
        });
      });
      sortBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          activeSort = btn.dataset.sort;
          sortBtns.forEach(b => {
            const isActive = b === btn;
            b.classList.toggle('is-active', isActive);
            b.setAttribute('aria-checked', isActive ? 'true' : 'false');
          });
          apply();
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  /* Tuck the section header tighter to the grid */
  :global(.photo-intro) { padding-bottom: 32px !important; }

  .photo-trigger {
    all: unset;
    display: block;
    width: 100%;
    cursor: zoom-in;
  }
  .photo-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
</style>
